<%- include('../partials/head.ejs')%>
</head>
<body>
  <%- include('../partials/nav.ejs')%>
  <main>
    <h1 class="page-title">❤️ Your Favourite Homes</h1>
    <div class="homes-list">
      <% if(favouriteHomes && favouriteHomes.length > 0) { %>
        <% favouriteHomes.forEach(home => { %>
          <div class="home-card">
            <div class="card-image-wrapper">
              <img src="<%= home.photo %>" alt="<%= home.homeName %>">
              <div class="card-overlay"></div>
            </div>
            <div class="card-content">
              <div class="card-header">
                <h3><%= home.homeName %></h3>
                <span class="price">₹<%= home.price %></span>
              </div>
              <div class="card-info">
                <p class="location"><strong>📍</strong> <%= home.location %></p>
                <p class="rating"><strong>⭐</strong> <%= home.rating %> Rating</p>
              </div>
              <div class="card-actions">
                <a href="/homes/<%=home._id%>" class="btn btn-details">View Details</a>
                <form action="/favourites/delete/<%= home._id %>" method="POST">
                  <button type="submit" class="btn btn-details">Remove From Favourite</button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="empty-state">
          <p>You haven't added any favourite homes yet.</p>
          <a href="/homes" class="add-home-btn">Browse Homes</a>
        </div>
      <% } %>
    </div>
    <%- include('../partials/footer.ejs') %>
  </main>
</body>
</html>